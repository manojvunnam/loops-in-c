#include <stdio.h>
int main() {
    int n;
    int total=0;
    int spikecount=0;
    scanf("%d",&n);
    int usage[n];
    for(int i=0;i<n;i++){
        scanf("%d",&usage[i]);
        total=total+usage[i];
        if(usage[i]>5){
            spikecount++;
        }
    }
    printf("total power:%d\n",total);
    printf("spike hours:%d\n",spikecount);
    return 0;
}
