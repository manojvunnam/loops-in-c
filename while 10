#include<stdio.h>
int main(){
int fuel,n;
int i=0,tripfuel;
int completed=0;
scanf("%d",&fuel);
scanf("%d",&n);
while(i<n){
scanf("%d",&tripfuel);
if(fuel>=tripfuel){
fuel=fuel-tripfuel;
completed++;
}else{
break;
}
i++;
}
printf("completed trips:%d\n",completed);
printf("remaining fuel:%d",fuel);
return 0;
}
