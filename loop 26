#include <stdio.h>
int main() {
    int N, expense;
    int total = 0, count = 0;
    scanf("%d", &N);
    for(int i = 0; i < N; i++) {
        scanf("%d", &expense);
        total += expense;
        if(expense > 1000) {
            count++;
        }
    }
    printf("Total Expense = %d\n", total);
    printf("Overspend Days = %d\n", count);
    return 0;
}
