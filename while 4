#include<stdio.h>
int main(){
int results[]={1,0,0,1,0,0,0,1,0};
int n=sizeof(results)/sizeof(results[0]);
int i=0;
int current_streak=0;
int max_streak=0;
while(i<n){
if(results[i]==0){
current_streak++;
if(current_streak>max_streak){
max_streak=current_streak;
}
}else{
current_streak=0;
}
i++;
}
printf("long failure streak:%d\n",max_streak);
return 0;
}
