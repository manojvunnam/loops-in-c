#include <stdio.h>
int main() {
    int N;
    int mark;
    int total = 0;
    int failedSubjects = 0;
    scanf("%d", &N);
    for(int i = 0; i < N; i++) {
        scanf("%d", &mark);
        total += mark;
        if(mark < 40) {
            failedSubjects++;
        }
    }
    int average = total / N;
    printf("Average Score: %d\n", average);
    printf("Failed Subjects: %d\n", failedSubjects);
    return 0;
}
