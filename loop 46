#include<stdio.h>
int main(){
int n;
scanf("%d",&n);
int overtime_hours=0;
int hours=0;
int overtime_days=0;
for(i=0;i<n;i++){
scanf("%d",&hours);
overtime_hours=overtime_hours+hours;
if(hours>3){
overtime_days++;
}
int overtime_cost=overtime_hours*200;
printf("overtime_hours=%d\n",overtime_hours);
printf("overtime_cost=%d\n",overtime_cost);
printf("overtime_days=%d\n",overtime_days);
return 0;
}
