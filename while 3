#include<stdio.h>
int main(){
int n;
scanf("%d",&n);
int totaldata;
scanf("%d",&totaldata);
int usage[n];
for(int i=0;i<n;i++){
scanf("%d",&usage[i]);
}
int days=0;
int i=0;
while((i<n)&&(totaldata>0)){
if(totaldata>=usage[i]){
totaldata=totaldata-usage[i];
days++;
}else{
break;
}
i++;
}
printf("days:%d\n",days);
printf("data:%d\n",totaldata);
return 0;
}
