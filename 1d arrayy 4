#include <stdio.h>
void reverseRoute(int arr[], int n) {
    int left = 0;
    int right = n - 1;
    int temp;
    while (left < right) {
        temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;
        left++;
        right--;
    }
}
int main() {
    int route[] = {101, 102, 103, 104, 105};
    int n = sizeof(route) / sizeof(route[0]);
    reverseRoute(route, n);
    printf("Reversed route: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", route[i]);
    }
    return 0;
}
