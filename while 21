#include<stdio.h>
int main(){
int n;
scanf("%d",&n);
int arr[n];
int i=0;
while(i<n){
scanf("%d",&arr[i]);
i++;
}
int totaldrops=0;
int maxdrop=0;
int crashday=0;
i=1;
while(i<n){
if(arr[i]<arr[i-1]){
totaldrops++;
int drop=arr[i-1]-arr[i];
if(drop>maxdrop){
maxdrop=drop;
crashday=i+1;
}
}
i++;
}
printf("crash day:%d\n",crashday);
printf("total drops:%d",totaldrops);
return 0;
}
